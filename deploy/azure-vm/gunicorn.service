[Unit]
Description=Gunicorn service for stock_portfolio_manage_v2
After=network.target

[Service]
User=azureuser
Group=www-data
WorkingDirectory=/var/www/stock_portfolio_manage_v2/backend
EnvironmentFile=/var/www/stock_portfolio_manage_v2/backend/.env
ExecStart=/var/www/stock_portfolio_manage_v2/backend/.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8000 --workers 3 --timeout 180
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target

